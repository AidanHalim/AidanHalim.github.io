---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Role {
  title: string;
  place: string;
  dates: string;
  type?: string;
  bullets: string[];
}

const roles: Role[] = [
  {
    title: 'Freelance Video Editor & Website Designer',
    place: 'PowerSwing Jakarta',
    dates: 'Dec 2022 – Dec 2025',
    type: 'Freelance',
    bullets: [
      'Edited 10+ videos, including promos and event highlights, for Instagram, YouTube, and the company website using Adobe Premiere Pro and DaVinci Resolve',
      "Managed the company's YouTube channel end to end, handling uploads, optimization, and audience growth to a combined 30K+ views",
      'Led website design planning in collaboration with an external agency, and maintained the backend with ongoing updates and additions',
      'Worked closely with internal staff and external partners, building cross-team communication across both creative and technical work',
    ],
  },
  {
    title: 'Marketing Officer',
    place: 'Computing and Information Systems Student Association (CISSA), University of Melbourne',
    dates: 'Nov 2024 – June 2026',
    bullets: [
      "Filmed, edited, and starred in promotional content (Instagram Reels, posts, and YouTube videos) for one of the university's largest tech student societies",
      'Produced cinematics, skits, interviews, and event montages promoting hackathons, study sessions, competitions, and meetups',
      'Wrote and directed several cinematic pieces in addition to editing them, taking promos from concept through to final cut',
      'Collaborated with the marketing team to plan content calendars and align video output with event campaigns',
    ],
  },
];
---

<BaseLayout
  title="Aidan Halim, Video Editor — Experience"
  description="Past roles and responsibilities in Aidan Halim's video editing experience, from freelance client work to university student media."
>
  <h1>Experience</h1>
  <p class="intro">A summary of my editing roles to date.</p>

  {roles.map((role) => (
    <section class="role">
      <div class="role__header">
        <h2>{role.title}</h2>
        {role.type && <span class="role__badge">{role.type}</span>}
      </div>
      <p class="role__meta">{role.place} &middot; {role.dates}</p>
      <ul>
        {role.bullets.map((bullet) => <li>{bullet}</li>)}
      </ul>
    </section>
  ))}
</BaseLayout>
