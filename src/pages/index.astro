---
import BaseLayout from '../layouts/BaseLayout.astro';

const skillGroups = [
  {
    name: 'Technical',
    skills: [
      'Adobe Premiere Pro',
      'DaVinci Resolve',
      'Color grading',
      'Sound design & effects',
      'Motion graphics & keyframing',
      'Visual effects',
      'Subtitling',
    ],
  },
  {
    name: 'Creative & Production',
    skills: [
      'Directing',
      'Writing & scripting',
      'Filming & cinematography',
      'Music selection',
      'On-camera presenting',
    ],
  },
];
---

<BaseLayout
  title="Aidan Halim, Video Editor"
  description="Aidan Halim is a video editor who takes projects from concept to final cut — directing, writing, filming, and editing client and personal work."
>
  <section class="hero">
    <h1 class="hero__name">Aidan Halim</h1>
    <p class="hero__role">Video Editor</p>
    <p class="hero__positioning">
      I take projects from concept to final cut, directing, writing, and filming as
      well as editing. My work spans client projects for a Jakarta aerial-sports
      studio and a Melbourne tech society, alongside personal creative films.
    </p>
    <a class="button" href="/work">View work</a>
  </section>

  <section class="skills">
    <p class="intro">From the edit suite to the director's chair.</p>
    <div class="skills__groups">
      {skillGroups.map((group) => (
        <div class="skills__group">
          <h2 class="skills__heading">{group.name}</h2>
          <ul class="skills__list">
            {group.skills.map((skill) => <li>{skill}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
